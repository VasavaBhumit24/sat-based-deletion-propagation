def sat_dp_ss_pipeline(query, database_instance, target_proj, w_tuple=1):
    import timeit
    from pysat.examples.rc2 import RC2

    solve_start_time = timeit.default_timer()

    # -------------------------
    # 1. Prepare Data
    # -------------------------
    witnesses_raw, projections_raw = prepare_data(query, database_instance)

    if not witnesses_raw or not projections_raw:
        return {
            'DP_SS_Deleted_Tuples_Count': 0,
            'Deleted_Tuples': [],
            'Solve_Time': 0,
            'Total_Witnesses_Encoded': 0,
            'Target': target_proj
        }

    # -------------------------
    # 2. Target Witness Extraction
    # -------------------------
    target_witness_keys = projections_raw.get(target_proj, [])

    if not target_witness_keys:
        print(f"⚠️ Target {target_proj} not found or has no witnesses.")
        return {
            'DP_SS_Deleted_Tuples_Count': 0,
            'Deleted_Tuples': [],
            'Solve_Time': 0,
            'Total_Witnesses_Encoded': 0,
            'Target': target_proj
        }

    # -------------------------
    # 3. Build Local Witness Map
    # -------------------------
    witness_map_local = {}
    counter = 0

    for raw_w_key in target_witness_keys:
        w_name = f"W_{counter}"
        counter += 1

        tuple_names = [
            t for t in raw_w_key.split('-')
            if t.startswith("T_")
        ]

        witness_map_local[w_name] = tuple_names

    # -------------------------
    # 4. Projection Map
    # -------------------------
    projection_map_local = {
        target_proj: list(witness_map_local.keys())
    }

    # -------------------------
    # 5. SAT Encoding
    # -------------------------
    encoder = SATEncoder()

    encoder.add_dependency_constraints(
        witness_map_local,
        projection_map_local,
        mode="dp_ss"
    )

    encoder.set_dp_ss_objective(
        target_proj,
        projection_map_local,
        w_tuple=w_tuple
    )

    # -------------------------
    # 6. Solve
    # -------------------------
    rc2 = RC2(encoder.wcnf)
    model = rc2.compute()

    solve_time = timeit.default_timer() - solve_start_time

    if model is None:
        return {
            'DP_SS_Deleted_Tuples_Count': -1,
            'Deleted_Tuples': [],
            'Solve_Time': solve_time,
            'Total_Witnesses_Encoded': len(witness_map_local),
            'Target': target_proj
        }

    # -------------------------
    # 7. Extract Deleted Tuples
    # -------------------------
    deleted_tuples = []
    model_set = set(model)

    for name, var_id in encoder.var_map.items():
        if name.startswith("T_") and -var_id in model_set:
            deleted_tuples.append(name)

    # -------------------------
    # 8. Return
    # -------------------------
    return {
        'DP_SS_Deleted_Tuples_Count': len(deleted_tuples),
        'Deleted_Tuples': deleted_tuples,
        'Solve_Time': solve_time,
        'Total_Witnesses_Encoded': len(witness_map_local),
        'Target': target_proj
    }

    def sat_dp_vs_pipeline(query, database_instance, target_proj, w_projection=1):

    import timeit
    from pysat.examples.rc2 import RC2

    results = {}
    solve_start_time = timeit.default_timer()

    # 1. Prepare Data
    witnesses_raw, projections_raw = prepare_data(query, database_instance)

    if not witnesses_raw or not projections_raw:
        return {'DP_VS_Deleted_Tuples_Count': 0, 'Solve_Time': 0, 'Deleted_Projections': [], 'Total_Witnesses_Encoded': 0, 'Total_Projections_Encoded': 0}

    # 2. Map building
    witness_map_for_encoder = {}
    projection_map_for_encoder = {}
    witness_name_map = {}
    counter = 0

    for proj_key, raw_witness_keys in projections_raw.items():
        projection_map_for_encoder[proj_key] = []
        for raw_w_key in raw_witness_keys:
            if raw_w_key not in witness_name_map:
                w_name = f"W_{counter}"
                witness_name_map[raw_w_key] = w_name
                counter += 1
                # Extract tuple names
                tuple_names = [t for t in raw_w_key.split('-') if t.startswith("T_")]
                witness_map_for_encoder[w_name] = tuple_names
            else:
                w_name = witness_name_map[raw_w_key]
            projection_map_for_encoder[proj_key].append(w_name)

    # 3. SAT Encoding
    encoder = SATEncoder()

    # Mode "dp_vs" must implement: P -> OR(W), W -> AND(T), and ¬W -> OR(¬T)
    encoder.add_dependency_constraints(
        witness_map_for_encoder,
        projection_map_for_encoder,
        mode="dp_vs"
    )

    # 4. Objective: Target = False, Others = True (Soft)
    encoder.set_dp_vs_objective(
        target_proj,
        list(projection_map_for_encoder.keys()),
        w_projection=w_projection
    )

    # 5. Solve
    rc2 = RC2(encoder.wcnf)
    model = rc2.compute()
    solve_time = timeit.default_timer() - solve_start_time

    if model is None:
        return {'DP_VS_Deleted_Tuples_Count': -1, 'Solve_Time': solve_time, 'Deleted_Projections': [], 'Total_Witnesses_Encoded': len(witness_map_for_encoder), 'Total_Projections_Encoded': len(projection_map_for_encoder)}

    # 6. Extraction (Crucial Fix)
    deleted_projections = []
    deleted_tuples = []
    model_set = set(model)

    for name, var_id in encoder.var_map.items():
        # In RC2/WCNF: Negative variable = FALSE = DELETED
        if -var_id in model_set:
            if name.startswith("p-"):
                deleted_projections.append(name)
            elif name.startswith("T_"):
                deleted_tuples.append(name)

    # Ensure target is present
    if target_proj not in deleted_projections:
        deleted_projections.append(target_proj)

    return {
        'DP_VS_Deleted_Tuples_Count': len(deleted_tuples),
        'Deleted_Projections': deleted_projections, # Return the list, not its length
        'Solve_Time': solve_time,
        'Total_Witnesses_Encoded': len(witness_map_for_encoder),
        'Total_Projections_Encoded': len(projection_map_for_encoder)
    }

def sat_swp_pipeline(query, database_instance):

    import timeit

    results = {}
    tuples_to_keep = set()
    encoders = []

    all_witness_maps = []
    all_projection_maps = []
    stats = []

    connected_components = get_existential_cc(query)

    solve_start_time = timeit.default_timer()

    for cc in connected_components:

        # -------------------------
        # Prepare SAT structures
        # -------------------------
        witness_map, projection_map, component_projections = \
            _prepare_sat_problem_for_component(query, database_instance, cc)

        if not witness_map or not projection_map:
            continue

        all_witness_maps.append(witness_map)
        all_projection_maps.append(projection_map)

        # -------------------------
        # Build SAT model
        # -------------------------
        encoder = SATEncoder()

        encoder.add_dependency_constraints(
            witness_map,
            projection_map,
            mode="swp"
        )

        encoder.set_swp_objective(projection_map, witness_map)

        # -------------------------
        # Solve
        # -------------------------
        rc2 = RC2(encoder.wcnf)

        comp_start = timeit.default_timer()
        model = rc2.compute()
        comp_end = timeit.default_timer()

        if model is None:
            continue

        model_set = set(model)   # ✅ faster lookup
        encoders.append((encoder, model))

        # -------------------------
        # Extract KEPT tuples
        # -------------------------
        for name, var in encoder.var_map.items():
            if name.startswith("T_") and var in model_set:
                tuples_to_keep.add(name)

        # -------------------------
        # Stats
        # -------------------------
        stats.append({
            "witnesses": len(witness_map),
            "projections": len(projection_map),
            "solve_time": comp_end - comp_start
        })

    solve_end_time = timeit.default_timer()

    # -------------------------
    # Final Results
    # -------------------------
    results["Kept Tuples"] = sorted(tuples_to_keep)
    results["#Kept Tuples"] = len(tuples_to_keep)
    results["Solve Time"] = solve_end_time - solve_start_time

    results["encoders"] = encoders
    results["witness_maps"] = all_witness_maps
    results["projection_maps"] = all_projection_maps
    results["stats"] = stats

    return results

    import timeit
from pysat.examples.rc2 import RC2

def sat_resilience_pipeline(query, database_instance, w_tuple=1):
    """
    RESILIENCE (Boolean Query):

    Goal:
        Minimum number of tuple deletions required to make the query FALSE.

    Encoding:
        - Witness: w ↔ (t1 ∧ t2 ∧ ... ∧ tk)
        - HARD: all witnesses must be FALSE
        - SOFT: minimize tuple deletions

    Args:
        query: Query object
        database_instance: database
        w_tuple: weight for tuple preservation

    Returns:
        dict with results
    """

    solve_start_time = timeit.default_timer()
    tuples_deleted = set()
    results = {}

    print(f"\n--- Resilience Pipeline | w_tuple: {w_tuple} ---")

    # -------------------------
    # 1. Prepare data
    # -------------------------
    witnesses_raw, projections_raw = prepare_data(query, database_instance)

    if not witnesses_raw:
        print("No witnesses found.")
        return {
            'Resilience_Deleted_Tuples_Count': 0,
            'Solve_Time': timeit.default_timer() - solve_start_time,
            'Deleted_Tuples': [],
            'Total_Witnesses_Encoded': 0
        }

    # -------------------------
    # 2. Build witness map
    # -------------------------
    witness_map = {}
    witness_name_map = {}
    counter = 0

    for witness_list in projections_raw.values():
        for w_key in witness_list:

            if w_key not in witness_name_map:
                w_name = f"W_{counter}"
                witness_name_map[w_key] = w_name
                counter += 1

                # Extract tuple names
                tuple_names = w_key[2:].split('-')
                witness_map[w_name] = tuple_names

    print(f"  Encoded {len(witness_map)} witnesses")

    # -------------------------
    # 3. Initialize encoder
    # -------------------------
    encoder = SATEncoder()

    # -------------------------
    # 4. Add witness constraints
    # -------------------------
    for w_name, tuple_list in witness_map.items():
        w_var = encoder.var(w_name)
        t_vars = [encoder.var(t) for t in tuple_list]

        # w → t_i
        for t in t_vars:
            encoder.add_clause([-w_var, t])

        # (t1 ∧ t2 ∧ ...) → w
        encoder.add_clause([-t for t in t_vars] + [w_var])

    # -------------------------
    # 5. HARD: kill all witnesses
    # -------------------------
    for w_name in witness_map:
        encoder.add_clause([-encoder.var(w_name)])

    # -------------------------
    # 6. SOFT: minimize deletions
    # -------------------------
    for name, var_id in encoder.var_map.items():
        if name.startswith("T_"):
            encoder.add_soft([var_id], weight=w_tuple)

    # -------------------------
    # 7. Solve
    # -------------------------
    rc2 = RC2(encoder.wcnf)
    model = rc2.compute()

    if model is None:
        print("Solver returned no model.")
        return {
            'Resilience_Deleted_Tuples_Count': -1,
            'Solve_Time': timeit.default_timer() - solve_start_time,
            'Deleted_Tuples': [],
            'Total_Witnesses_Encoded': len(witness_map)
        }

    # -------------------------
    # 8. Extract deleted tuples
    # -------------------------
    for lit in model:
        if lit < 0:
            name = encoder.reverse_map.get(-lit, "")
            if name.startswith("T_"):
                tuples_deleted.add(name)

    # -------------------------
    # 9. Consistency check
    # -------------------------
    all_tuples = [n for n in encoder.var_map if n.startswith("T_")]
    print(f"  Checking consistency for {len(all_tuples)} tuples...")
    encoder.check_encode_decode_consistency(all_tuples)

    solve_end_time = timeit.default_timer()

    # -------------------------
    # 10. Return results
    # -------------------------
    results = {
        'Resilience_Deleted_Tuples_Count': len(tuples_deleted),
        'Solve_Time': solve_end_time - solve_start_time,
        'Deleted_Tuples': list(tuples_deleted),
        'Total_Witnesses_Encoded': len(witness_map)
    }

    return results
